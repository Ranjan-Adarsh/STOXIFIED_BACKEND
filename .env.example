DB_HOST=localhost
DB_PORT=5432
DB_NAME=newsdb
DB_USER=postgres
DB_PASS=your_db_password_here
SECRET_KEY=replace_with_a_strong_secret_key
ALGORITHM=your_preferred_algorithm_here
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Docker Hub settings for GitHub Actions deployment
DOCKERHUB_USERNAME=your_dockerhub_username
DOCKERHUB_REPOSITORY=your_dockerhub_repository_name
